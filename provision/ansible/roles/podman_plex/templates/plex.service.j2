{{ ansible_managed|comment }}

[Unit]
Description=Plex
Documentation=https://watch.plex.tv/
Wants=network-online.target
After=network-online.target
RequiresMountsFor={{ podman_plex_basedir }} {{ podman_plex_mediadir }}
StartLimitIntervalSec=10

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
Restart=on-failure
RestartSec=10
StartLimitBurst=3
# docker.io rate-limit delays can abort startup if timeout is too short.
TimeoutStartSec=300
TimeoutStopSec=70
ExecStartPre=/bin/rm --force %t/%n.pid %t/%n.ctr-id
ExecStartPre=-/usr/bin/podman pull {{ registry_ghcrio }}/oliversalzburg/containers/plex:{{ podman_plex_version }}
ExecStart=/usr/bin/podman run \
  --cgroups "no-conmon" \
  --cidfile "%t/%n.ctr-id" \
  --conmon-pidfile "%t/%n.pid" \
  --detach \
  --group-add "{{ ansible_facts["getent_group"]["nas"][1] }}" \
  --group-add "{{ ansible_facts["getent_group"]["render"][1] }}" \
  --hostname "%n.{{ inventory_hostname }}" \
  --label "traefik.enable=true" \
  --label "traefik.http.routers.plex.entrypoints=websecure" \
  --label "traefik.http.routers.plex.tls.certresolver={{ realm }}" \
  --label "traefik.http.routers.plex.tls.domains[0].main=%N.web.{{ inventory_hostname }}" \
  --label "traefik.http.routers.plex.rule=Host(`%N.web.{{ inventory_hostname }}`)" \
  --label "traefik.http.services.plex.loadbalancer.healthcheck.path=/health" \
  --label "traefik.http.services.plex.loadbalancer.server.port=32400" \
  --log-driver "journald" \
  --memory "4g" \
  --name "%n.{{ inventory_hostname }}" \
  --network host \
  --pull "never" \
  --replace \
  --rm \
  --user "{{ _podman_plex_user.uid }}:{{ _podman_plex_groups.results[0].gid }}" \
  --volume "/etc/ssl/certs/ca-certificates.crt:/etc/ssl/certs/ca-certificates.crt:ro" \
  --volume "{{ podman_plex_mediadir }}/data/media:/media:ro" \
  --volume "{{ podman_plex_basedir }}/config:/config:rw" \
  oliversalzburg/containers/plex:{{ podman_plex_version }}

ExecStop=/usr/bin/podman stop --ignore --cidfile "%t/%n.ctr-id" --time 10
ExecStopPost=/usr/bin/podman rm --ignore --force --cidfile "%t/%n.ctr-id"
PIDFile=%t/%n.pid
Type=forking

[Install]
WantedBy=multi-user.target
